# OpenAI API Key (optional)
# Get your API key from: https://platform.openai.com/api-keys
# If not provided, the AI will use rule-based responses
VITE_OPENAI_API_KEY=your-api-key-here

# Supabase (for saving experiment data on Finish – e.g. Netlify deploy)
# Create a project at https://supabase.com, then run the SQL in docs/supabase_schema.sql to create the table.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
